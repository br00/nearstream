# Copy this file to `.env.local` and fill in the values:
#   cp .env.example .env.local

# ---- Cloudflare R2 — durable storage for stream entries -----------------
# If any of these is missing, the app falls back to the in-memory store.
#
# Where to find these:
#   1. Cloudflare dashboard → R2 → Overview → "Account ID" (top right) → R2_ACCOUNT_ID
#   2. Cloudflare dashboard → R2 → Manage R2 API Tokens → "Create API token"
#        Permissions: Object Read & Write
#        Bucket: choose the bucket you'll use (or "All buckets")
#        → Access Key ID    → R2_ACCESS_KEY_ID
#        → Secret Access Key → R2_SECRET_ACCESS_KEY  (shown once, copy now)
#   3. The bucket name you created → R2_BUCKET

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ---- Auth — required to sign in to /studio ------------------------------
# AUTH_SECRET signs session cookies + magic-link tokens (HMAC-SHA256).
# Generate one with:  openssl rand -base64 32
# Rotate it to instantly invalidate every existing session + magic link.
AUTH_SECRET=

# Comma-separated list of emails allowed to sign in.
# Anyone else gets the same "if that email is on the allowlist..." response —
# the app does not reveal whether an address is on the list.
# Adding a friend = add their email + redeploy. Friction by design.
ALLOWED_EMAILS=

# ---- Site URL — used for RSS feed item links + metadataBase -------------
# Absolute origin of the deployed site. No trailing slash.
# Local dev defaults to http://localhost:3000 if unset.
# Production: set to e.g. https://nearstream.xyz.
NEARSTREAM_SITE_URL=

# ---- Multi-tenant (Phase 3) -------------------------------------------
# The instance host — gets a deterministic handle on first sign-in and is
# the only user who can run /api/admin/migrate-host.
HOST_USER_EMAIL=
HOST_USER_HANDLE=alessandro
HOST_USER_NAME=Alessandro Borelli

# Map custom domains to tenant handles. Format: `domain:handle,domain:handle`.
# The proxy reads the host header and rewrites tenant-custom-domain requests
# internally to /{handle}/... — the URL bar stays clean.
# Example: TENANT_DOMAINS=alessandroborelli.it:alessandro,gosia.pl:gosia
TENANT_DOMAINS=

# ---- Resend — for sending the magic-link email --------------------------
# If either RESEND_API_KEY or RESEND_FROM is missing, the app prints the
# magic link to the server console instead of emailing it (dev mode).
#
# Where to find these:
#   1. resend.com → API Keys → Create API Key → RESEND_API_KEY
#   2. RESEND_FROM must be on a domain you've verified in Resend.
#      For local dev you can use `onboarding@resend.dev` (Resend's shared sender).
RESEND_API_KEY=
RESEND_FROM=
