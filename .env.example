# Cloudflare R2 — required for the R2-backed store.
# If any of these is missing, the app falls back to the in-memory store.
#
# Where to find these:
#   1. Cloudflare dashboard → R2 → Overview → "Account ID" (top right) → R2_ACCOUNT_ID
#   2. Cloudflare dashboard → R2 → Manage R2 API Tokens → "Create API token"
#        Permissions: Object Read & Write
#        Bucket: choose the bucket you'll use (or "All buckets")
#        → Access Key ID    → R2_ACCESS_KEY_ID
#        → Secret Access Key → R2_SECRET_ACCESS_KEY  (shown once, copy now)
#   3. The bucket name you created → R2_BUCKET
#
# Copy this file to `.env.local` and fill in the values:
#   cp .env.example .env.local

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
